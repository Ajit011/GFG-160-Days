Q4--> Rotate Array 
//   Approach --we have to rotate left 
//   ** ( if arr.length<k) {
//   k = arr.length%k--
//     }
// code-->
class Solution {
   public  static void rotate(int i,int j,int arr[]){
        while(i<j){
            int temp = arr[i];
            arr[i] = arr[j];
            arr[j] = temp;
            i++;
            j--;
        }
    }
    static void rotateArr(int arr[], int d) {
        int n = arr.length;
        int k = d;
        if(d>n) {
            k = d%n;
        }
        rotate(0,k-1,arr);
         rotate(k,n-1,arr);
         rotate(0,n-1,arr); 
    }
}
// Time Complexity-> O(n) * 3 ~ O(n)
  
