// Q.6-> Majority element (store in a arrayList where freq is more then arr.length/3)
Optimized -> using TreeMap 
// store freq in TreeMap 
// Store in list whose freq is >arr.length/3

Code -> 
class Solution {
    public ArrayList<Integer> findMajority(int[] arr) {
      // make a array list
      ArrayList<Integer> list = new ArrayList<>();
      // make hashmap--
      TreeMap<Integer,Integer> map = new TreeMap<>();
      // calculate freq from array
      for(int ele: arr){
          if(map.containsKey(ele)){
              map.put(ele,map.get(ele)+1);
          }
          else map.put(ele,1);
      }
      // check whose freq is more then n/3 times stores in the array
      for(int key: map.keySet()){
          int freq = map.get(key);
          if(freq>arr.length/3) list.add(key);
      }
      return list; 
    }
}

// Time Complexity-> O(n) 
// Space Complexity -> O(n)

  
