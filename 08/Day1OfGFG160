  Q2.Move all Zero To End ->>>
  Code --
  class Solution {
    void pushZerosToEnd(int[] arr) {
        // code here
        int j = 0;
        int n = arr.length;
        for(int i=0;i<n;i++){
            if(arr[i]!=0){
                int temp = arr[i];
                arr[i] = arr[j];
               arr[j] = temp;
               j++;
            }
        }
        
    }
}

